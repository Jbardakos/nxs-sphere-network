{
  "name": "nxs-sphere-network",
  "productName": "NXS+ Sphere Network",
  "version": "1.0.0",
  "description": "∅ NXS+ Sphere Network — 3D concept network for transdisciplinary creative research",
  "main": "main.js",
  "author": {
    "name": "Iannis Bardakos",
    "email": "bardakos@uic.edu.cn"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.cognitivenexus.nxs",
    "productName": "NXS+ Sphere Network",
    "copyright": "Copyright © 2025 Iannis Bardakos / CognitiveNexus",
    "files": [
      "main.js",
      "index.html",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Education",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
