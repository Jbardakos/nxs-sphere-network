# NXS+ Whisper Server Configuration
# Copy this file to .env and adjust values as needed

# Whisper model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=base

# Host and port for the local transcription server
HOST=0.0.0.0
PORT=8765

# Device: cpu or cuda (if GPU available)
DEVICE=cpu

# Compute type: int8 (CPU), float16 (GPU)
COMPUTE_TYPE=int8

# Optional: OpenAI API key (fallback if local server not used)
# OPENAI_API_KEY=sk-...
